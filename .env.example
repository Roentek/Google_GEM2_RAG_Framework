# API Keys and Environment Variables
# Fill in your real values below — NEVER commit this file

# === Supabase ===
SUPABASE_API_PAT=""                       # Supabase personal access token (MCP)
SUPABASE_PROJECT_URL=""                   # e.g. https://xyzabc.supabase.co
SUPABASE_PROJECT_KEY=""                   # anon/service role key from Supabase dashboard

# === Gemini ===
GEMINI_API_KEY=""                         # Google AI Studio API key

# === OpenRouter ===
OPENROUTER_API_KEY=                       # OpenRouter API key
OPENROUTER_MODEL=anthropic/claude-sonnet-4  # OpenRouter model to use for answer generation (default: Claude Sonnet 4)